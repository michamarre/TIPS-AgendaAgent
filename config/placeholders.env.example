# =============================================================
# VORLAGE: Kopiere diese Datei zu placeholders.env
# und trage echte Werte ein.
# placeholders.env ist in .gitignore.
# =============================================================

# Azure / OpenAI (optional fuer spaetere KI-Unterstuetzung)
AZURE_TENANT_ID={{AZURE_TENANT_ID}}
AZURE_CLIENT_ID={{AZURE_CLIENT_ID}}
AZURE_CLIENT_SECRET={{AZURE_CLIENT_SECRET}}
AZURE_OPENAI_ENDPOINT={{AZURE_OPENAI_ENDPOINT}}
AZURE_OPENAI_DEPLOYMENT={{AZURE_OPENAI_DEPLOYMENT}}
AZURE_OPENAI_API_KEY={{AZURE_OPENAI_API_KEY}}

# n8n
N8N_WEBHOOK_BASE_URL={{N8N_WEBHOOK_BASE_URL}}
N8N_WEBHOOK_SECRET={{N8N_WEBHOOK_SECRET}}
N8N_API_KEY={{N8N_API_KEY}}
N8N_API_BASE={{N8N_API_BASE}}

# VPS / SSH
VPS_HOST={{VPS_HOST}}
VPS_USER={{VPS_USER}}
SSH_KEY_FILENAME={{SSH_KEY_FILENAME}}

# GitHub
GITHUB_REPO_URL={{GITHUB_REPO_URL}}
GITHUB_BRANCH=main

# Agenda-Mailbox
# Fuer den aktuellen Outlook-Ordner-MVP bewusst noch nicht noetig.
# Werte koennen bis zur Mailbox-Ausbaustufe auf `MVP_DEFERRED` stehen.
AGENDA_MAIL_ADDRESS={{AGENDA_MAIL_ADDRESS}}
AGENDA_IMAP_HOST={{AGENDA_IMAP_HOST}}
AGENDA_IMAP_PORT={{AGENDA_IMAP_PORT}}
AGENDA_IMAP_USER={{AGENDA_IMAP_USER}}
AGENDA_IMAP_PASSWORD={{AGENDA_IMAP_PASSWORD}}
AGENDA_SMTP_HOST={{AGENDA_SMTP_HOST}}
AGENDA_SMTP_PORT={{AGENDA_SMTP_PORT}}
AGENDA_SMTP_USER={{AGENDA_SMTP_USER}}
AGENDA_SMTP_PASSWORD={{AGENDA_SMTP_PASSWORD}}

# Nextcloud / Deck
NEXTCLOUD_BASE_URL=https://fh-swf.sciebo.de
NEXTCLOUD_USERNAME={{NEXTCLOUD_USERNAME}}
NEXTCLOUD_APP_PASSWORD={{NEXTCLOUD_APP_PASSWORD}}
NEXTCLOUD_BASIC_AUTH={{NEXTCLOUD_BASIC_AUTH}}
NEXTCLOUD_DECK_BOARD_ID=1919
NEXTCLOUD_DECK_BOARD_NAME={{NEXTCLOUD_DECK_BOARD_NAME}}
NEXTCLOUD_FILES_ROOT={{NEXTCLOUD_FILES_ROOT}}

# Workflow-Konfiguration
# Fuer den aktuellen MVP sind Outlook-User, Folder-ID und Board-Konfiguration relevant.
AGENDA_OUTLOOK_USER={{AGENDA_OUTLOOK_USER}}
AGENDA_OUTLOOK_FOLDER_ID={{AGENDA_OUTLOOK_FOLDER_ID}}
AGENDA_POLL_TOP=20
AGENDA_DEFAULT_CATEGORY={{AGENDA_DEFAULT_CATEGORY}}
AGENDA_DEFAULT_PREPARATION_OWNER={{AGENDA_DEFAULT_PREPARATION_OWNER}}
AGENDA_STATUS_INBOX={{AGENDA_STATUS_INBOX}}
AGENDA_STATUS_PREPARATION={{AGENDA_STATUS_PREPARATION}}
AGENDA_STATUS_FRIDAY={{AGENDA_STATUS_FRIDAY}}
AGENDA_STATUS_DECIDED={{AGENDA_STATUS_DECIDED}}
AGENDA_STATUS_TODO={{AGENDA_STATUS_TODO}}
AGENDA_STATUS_DONE={{AGENDA_STATUS_DONE}}
WEEKLY_DIGEST_RECIPIENTS={{WEEKLY_DIGEST_RECIPIENTS}}
WEEKLY_DIGEST_CRON={{WEEKLY_DIGEST_CRON}}
TODO_REMINDER_CRON={{TODO_REMINDER_CRON}}
